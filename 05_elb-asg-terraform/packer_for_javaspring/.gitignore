# =========================
# Spring Boot / Maven Build
# =========================
# target 폴더 전체 무시
target/
# 단, 사용자 요청에 따라 컴파일된 최종 jar 샘플 파일은 Git에 포함 (추적 허용)
!target/*.jar
# 빌드 시 생성되는 불필요한 원본 백업 jar 파일은 다시 무시
target/*.jar.original

# Maven 관련 기타 파일 무시
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# =========================
# Java & Logs
# =========================
*.class
*.log
hs_err_pid*
replay_pid*

# =========================
# Package Files (Except specific target jar)
# =========================
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# =========================
# IDE & OS Files
# =========================
.idea/
*.iml
*.iws
.project
.classpath
.settings/
.vscode/
.DS_Store
Thumbs.db
