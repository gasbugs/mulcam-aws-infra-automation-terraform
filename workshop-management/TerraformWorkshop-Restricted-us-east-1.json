{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowAllServices",
            "Effect": "Allow",
            "Action": "*",
            "Resource": "*"
        },
        {
            "Sid": "DenyAllServicesOutsideUsEast1",
            "Effect": "Deny",
            "Action": "*",
            "Resource": "*",
            "Condition": {
                "StringNotEqualsIfExists": {
                    "aws:RequestedRegion": "us-east-1"
                }
            }
        },
        {
            "Sid": "DenyCostlyServicesAndSubscriptions",
            "Effect": "Deny",
            "Action": [
                "ec2:PurchaseReservedInstancesOffering",
                "ec2:ModifyReservedInstances",
                "ec2:CreateReservedInstancesListing",
                "rds:PurchaseReservedDBInstancesOffering",
                "elasticache:PurchaseReservedCacheNodesOffering",
                "redshift:PurchaseReservedNodeOffering",
                "es:PurchaseReservedInstanceOffering",
                "savingsplans:*",
                "shield:CreateSubscription",
                "shield:UpdateSubscription",
                "shield:AssociateDRTRole",
                "guardduty:CreateDetector",
                "guardduty:UpdateDetector",
                "securityhub:EnableSecurityHub",
                "securityhub:UpdateSecurityHubConfiguration",
                "macie2:EnableMacie",
                "macie2:UpdateMacieSession",
                "inspector2:Enable",
                "detective:CreateGraph",
                "aws-marketplace:Subscribe",
                "aws-marketplace:Unsubscribe",
                "aws-marketplace:CancelAgreement"
            ],
            "Resource": "*"
        },
        {
            "Sid": "DenyModifyOrDeleteTerraformUser0",
            "Effect": "Deny",
            "Action": [
                "iam:DeleteUser",
                "iam:UpdateUser",
                "iam:DeleteLoginProfile",
                "iam:UpdateLoginProfile",
                "iam:CreateLoginProfile",
                "iam:AttachUserPolicy",
                "iam:DetachUserPolicy",
                "iam:PutUserPolicy",
                "iam:DeleteUserPolicy",
                "iam:AddUserToGroup",
                "iam:RemoveUserFromGroup",
                "iam:CreateAccessKey",
                "iam:DeleteAccessKey",
                "iam:UpdateAccessKey",
                "iam:DeactivateMFADevice",
                "iam:EnableMFADevice",
                "iam:DeleteVirtualMFADevice",
                "iam:TagUser",
                "iam:UntagUser"
            ],
            "Resource": "arn:aws:iam::*:user/terraform-user-0"
        },
        {
            "Sid": "DenyHighCostInstanceTypes",
            "Effect": "Deny",
            "Action": "ec2:RunInstances",
            "Resource": "arn:aws:ec2:*:*:instance/*",
            "Condition": {
                "ForAnyValue:StringLike": {
                    "ec2:InstanceType": [
                        "*.metal",
                        "*.12xlarge",
                        "*.16xlarge",
                        "*.18xlarge",
                        "*.24xlarge",
                        "*.32xlarge",
                        "*.48xlarge",
                        "p*.*",
                        "g*.*",
                        "inf*.*",
                        "trn*.*",
                        "dl*.*",
                        "x*.*",
                        "u-*.*",
                        "hpc*.*"
                    ]
                }
            }
        }
    ]
}